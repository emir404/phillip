{
  "name": "@nutz/phillip",
  "version": "0.1.0",
  "description": "The autonomous preview-to-paid embed. Drops Phillip onto any auto-generated website preview: tracks behavior, opens a chat, iterates, and closes \u2014 all backend-driven from a single previewId.",
  "type": "module",
  "license": "UNLICENSED",
  "private": false,
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/preview.global.js",
  "jsdelivr": "./dist/preview.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./preview.js": "./dist/preview.global.js",
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "css": "node scripts/build-css.mjs",
    "predev": "node scripts/build-css.mjs",
    "dev": "vite",
    "prebuild": "node scripts/build-css.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/build-css.mjs",
    "test": "vitest run",
    "pretest:watch": "node scripts/build-css.mjs",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome check --write .",
    "size": "size-limit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18.2",
    "react-dom": ">=18.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@tailwindcss/cli": "^4.3.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^15.11.7",
    "jsdom": "^29.1.1",
    "msw": "^2.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "size-limit": "^11.1.6",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "msw": {
    "workerDirectory": ["playground/public"]
  },
  "size-limit": [
    {
      "name": "drop-in IIFE (react bundled)",
      "path": "dist/preview.global.js",
      "limit": "120 kB"
    },
    {
      "name": "react entry (esm)",
      "path": "dist/index.js",
      "limit": "61 kB"
    }
  ],
  "dependencies": {
    "clsx": "^2.1.1",
    "motion": "^12.42.0",
    "tailwind-merge": "^3.6.0"
  }
}
