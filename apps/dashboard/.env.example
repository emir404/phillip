# --- Database (Turso / libsql) ---
# Local dev: file:.data/phillip.db  ·  Production: libsql://<db>.turso.io
TURSO_DATABASE_URL=file:.data/phillip.db
TURSO_AUTH_TOKEN=

# --- Auth (better-auth) ---
BETTER_AUTH_SECRET=            # openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:5174

# --- Phillip agent ---
ANTHROPIC_API_KEY=             # console.anthropic.com
PHILLIP_CHAT_MODEL=claude-haiku-4-5
# Sonnet edits source surgically and caches its prompt; opus is the expensive escape hatch.
PHILLIP_EXECUTOR_MODEL=claude-sonnet-5
PHILLIP_BUDGET_CAP_USD=5
PHILLIP_API_KEY=               # openssl rand -hex 24 — auth for the auto-mode preview API

# --- Stripe ---
# Live keys drive real leads; test keys serve leads with test_mode on, so a full
# purchase can be rehearsed with the 4242… card. One webhook URL, two endpoints.
STRIPE_SECRET_KEY=             # sk_live_... (sk_test_... is fine in dev)
STRIPE_WEBHOOK_SECRET=         # whsec_... from the live webhook endpoint
STRIPE_TEST_SECRET_KEY=        # sk_test_... — checkout for test_mode leads
STRIPE_TEST_WEBHOOK_SECRET=    # whsec_... from the test-mode endpoint (or `stripe listen`)

# --- GitHub (repo-backed leads) ---
# A lead with a repo gets its iterations committed and pushed; the repo's own
# Vercel integration builds them. Fine-grained PAT with Contents: read+write.
GITHUB_TOKEN=                  # github_pat_...
GITHUB_OWNER=                  # default owner for bare `repo` names

# --- Vercel (iteration deploys + domain connect) ---
# Use the PHILLIP_-prefixed names in production — Vercel reserves VERCEL_* for
# its own system env. The plain names also work locally.
PHILLIP_VERCEL_TOKEN=          # vercel.com/account/tokens
PHILLIP_VERCEL_TEAM_ID=        # team_... (empty for personal scope)
PHILLIP_DEPLOY_MODE=           # "off" = apply iteration edits without deploying or pushing

# --- Seed ---
SEED_ADMIN_PASSWORD=           # login password for the team accounts created by db:seed
SEED_ADMIN_EMAILS=             # comma-separated logins (default: emir@witharc.co)
