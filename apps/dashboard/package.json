{
  "name": "@nutz/dashboard",
  "version": "0.1.0",
  "description": "The nutz team's analytics dashboard + ingestion backend for Phillip — agents POST lead, event, and conversation data; it persists and visualizes the funnel.",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5174",
    "db:push": "drizzle-kit push",
    "db:seed": "node --env-file-if-exists=.env.local --import tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "build": "pnpm --filter @nutz/phillip build && node scripts/copy-embed.mjs && node scripts/ensure-assets-table.mjs && next build",
    "embed": "pnpm --filter @nutz/phillip build && node scripts/copy-embed.mjs",
    "start": "next start -p 5174",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@base-ui/react": "^1.6.0",
    "@libsql/client": "^0.17.4",
    "@nutz/phillip": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.0",
    "nanoid": "^5.1.16",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2"
  }
}
